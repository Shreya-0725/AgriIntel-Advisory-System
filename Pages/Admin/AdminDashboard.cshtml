@page
@model AgriIntel_Advisory_System.Pages.Admin.AdminDashboardModel
@{
	Layout = "_AdminLayout";
}

	
		<div class="main-panel">
			<div class="content">
				<div class="container-fluid">
					<h4 class="page-title">Dashboard</h4>
				<div class="row">
					<!-- Total Experts -->
					<div class="col-md-3">
                        <a asp-page="/Admin/ManageExperts" class="text-decoration-none">
							<div class="card card-stats card-warning">
								<div class="card-body">
									<div class="numbers text-center">
										<p class="card-category">Total Experts</p>
										<h4 class="card-title">17</h4>
									</div>
								</div>
							</div>
						</a>
					</div>

					<!-- Total Farmers -->
					<div class="col-md-3">
                        <a asp-page="/Admin/ManageFarmers" class="text-decoration-none">
							<div class="card card-stats card-success">
								<div class="card-body">
									<div class="numbers text-center">
										<p class="card-category">Total Farmers</p>
										<h4 class="card-title">15</h4>
									</div>
								</div>
							</div>
						</a>
					</div>

					<!-- Total Staff -->
					<div class="col-md-3">
                        <a asp-page="/Admin/ManageStaff" class="text-decoration-none">
							<div class="card card-stats card-danger">
								<div class="card-body">
									<div class="numbers text-center">
										<p class="card-category">Total Staff</p>
										<h4 class="card-title">5</h4>
									</div>
								</div>
							</div>
						</a>
					</div>

					<!-- Queries -->
					<div class="col-md-3">
                        <a asp-page="/Admin/ViewIssues" class="text-decoration-none">
							<div class="card card-stats card-primary">
								<div class="card-body">
									<div class="numbers text-center">
										<p class="card-category">Queries</p>
										<h4 class="card-title">4</h4>
									</div>
								</div>
							</div>
						</a>
					</div>
				</div>

                <!-- Recent Applications Table -->
                <div class="row mt-4">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h4 class="card-title">Recent Applications</h4>
                                <p class="card-category">Applications for Soil-test Assistance</p>
                            </div>
                            <div class="card-body">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Farmer Name</th>
                                            <th>Crop Type</th>
                                            <th>Field Location</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>1</td>
                                            <td>Ramesh Kumar</td>
                                            <td>Wheat</td>
                                            <td>Village A</td>
                                            <td>Pending</td>
                                        </tr>
                                        <tr>
                                            <td>2</td>
                                            <td>Palki Sharma</td>
                                            <td>Rice</td>
                                            <td>Village B</td>
                                            <td>Completed</td>
                                        </tr>
                                        <tr>
                                            <td>3</td>
                                            <td>Ajay Singh</td>
                                            <td>Maize</td>
                                            <td>Village C</td>
                                            <td>Pending</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Admin Buttons -->
                <div class="row mt-4">
                    <div class="col-md-3">
                        <a asp-page="/Admin/ViewIssues" class="btn btn-primary btn-block">View Farmers Issues</a>
                    </div>
                    <div class="col-md-3">
                        <a asp-page="/Admin/ManageSoilTests" class="btn btn-success btn-block">Manage Soil Tests</a>
                    </div>
                    <div class="col-md-3">
                        <a asp-page="/Admin/ManageKisaanKendra" class="btn btn-warning btn-block">Manage Kisaan Kendra</a>
                    </div>
                    <div class="col-md-3">
                        <a asp-page="/Admin/ManageArticles" class="btn btn-info btn-block">Manage Articles</a>
                    </div>
                </div>

                <!-- Summary Info Boxes -->
               
                <div class="row mt-4">
                    <div class="col-md-3">
                        <div class="card summary-card text-center">
                            <div class="card-body">
                                <h5>Pending Soil test Requests</h5>
                                <h3>12</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card summary-card text-center">
                            <div class="card-body">
                                <h5>Pending User Queries</h5>
                                <h3>3</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card summary-card text-center">
                            <div class="card-body">
                                <h5>Applications for crop issues</h5>
                                <h3>5</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card summary-card text-center">
                            <div class="card-body">
                                <h5>Registered Kisaan Kendra</h5>
                                <h3>4</h3>
                            </div>
                        </div>
                    </div>
                </div>


            </div>
        </div>

		</div>

