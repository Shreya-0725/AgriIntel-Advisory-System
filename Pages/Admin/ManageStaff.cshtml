
@page
@model AgriIntel_Advisory_System.Pages.Admin.ManageStaffModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Staff";
}

<div class="main-panel">
    <div class="content">
        <div class="page-inner">
            <h2 class="page-title">Manage Staff</h2>

            <!-- MESSAGE ALERT -->
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @Model.MessageClass" id="msgAlert">
                    @Model.Message
                </div>

                <script>
                    setTimeout(function () {
                        var msg = document.getElementById("msgAlert");
                        if (msg) {
                            msg.style.transition = "opacity 0.5s ease";
                            msg.style.opacity = "0";
                            setTimeout(function () { msg.remove(); }, 500);
                        }
                    }, 3000);
                </script>
            }

            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Emp ID</th>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var staff in Model.Staffs)
                    {
                        <tr>
                            <td>@staff.EmpId</td>
                            <td>@staff.FirstName @staff.LastName</td>
                            <td>@staff.MobileNo</td>
                            <td>@staff.Email</td>
                            <td>
                                <!-- View Staff -->
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="SelectedStaffId" value="@staff.EmpId" />
                                    <button class="btn btn-sm btn-info">View Details</button>
                                </form>

                                <!-- Delete Staff -->
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this staff?');">
                                    <input type="hidden" name="staffId" value="@staff.EmpId" />
                                    <button class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Selected Staff Details -->
            @if (Model.SelectedStaff != null)
            {
                <div class="mt-3 p-3 border rounded bg-light">
                    <h4>Staff Details</h4>
                    <p><strong>Emp ID:</strong> @Model.SelectedStaff.EmpId</p>
                    <p><strong>Name:</strong> @Model.SelectedStaff.FirstName @Model.SelectedStaff.LastName</p>
                    <p><strong>Mobile:</strong> @Model.SelectedStaff.MobileNo</p>
                    <p><strong>Email:</strong> @Model.SelectedStaff.Email</p>
                    <p><strong>Gender:</strong> @(string.IsNullOrEmpty(Model.SelectedStaff.Gender) ? "Not Specified" : Model.SelectedStaff.Gender)</p>
                    <p><strong>Address:</strong> @(string.IsNullOrEmpty(Model.SelectedStaff.Address) ? "Not Specified" : Model.SelectedStaff.Address)</p>
                </div>
            }
        </div>
    </div>
</div>