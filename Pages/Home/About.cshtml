@page
@model AgriIntel_Advisory_System.Pages.Home.AboutModel
@{
    Layout = "_Layout";
}


<style>
    /* FIX BANNER BG IMAGE */
    .page-banner-area {
        background-image: url('/assets/img/aboutus image.png');
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        padding: 120px 0;
        text-align: center;
        color: #fff;
    }

    /* FIX IMAGE SIZE (SAME FOR ALL) */
    .service-img {
        width: 100%;
        height: 260px;
        object-fit: cover;
    }
</style>


<!-- PAGE BANNER -->
<div class="page-banner-area">
    <h1 style="font-weight:900; font-size:50px; letter-spacing:2px; color:#fff; text-transform:uppercase;">
        About US
    </h1>

    <ul style="list-style:none; padding:0; margin-top:20px; display:inline-flex; gap:15px; font-size:18px; font-weight:700;">
        <li>
            <a asp-page="/Home/Index" style="color:#000; text-decoration:none;">
                Home
            </a>
        </li>
        <li style="color:#000;"> / </li>
        <li>
            <a asp-page="/Home/About" style="color:#000; text-decoration:none;">
                About Us
            </a>
        </li>
    </ul>

</div>


<!-- About Area Start -->
<div id="about-area" class="about-area section pt-120 pb-120">
    <div class="container">
        <div class="row">

            <!-- About Content -->
            <div class="about-content-2 col-lg-12 col-12" style="line-height:1.8; font-size:18px; color:#333;">
                <h2 style="font-weight:800; font-size:36px; margin-bottom:20px; color:#1a3d1a;">
                    About AgriIntel Advisory System
                </h2>

                <p>
                    <b>AgriIntel Advisory System</b> is a digital platform designed to empower farmers with expert guidance, real-time advice, and access to essential agricultural services.
                    Our goal is to make farming decisions easier and more accurate by providing timely information tailored to crop types, soil conditions, and weather patterns.
                </p>

                <ul style="list-style:none; padding-left:0; margin-top:20px;">
                    <li style="margin-bottom:15px;">
                        🌱 <b>Expert Guidance:</b> Farmers can consult agricultural experts directly through the system or with the assistance of <b>Kisan Sewa Kendra</b> staff.
                    </li>
                    <li style="margin-bottom:15px;">
                        📄 <b>Government Schemes:</b> Easily apply for crop insurance and <b>PM Kisan Samman Nidhi Yojana</b> through the platform.
                    </li>
                    <li style="margin-bottom:15px;">
                        🧪 <b>Soil Testing & Health:</b> Farmers can request soil tests and receive a personalized <b>Soil Health Card</b>.
                    </li>
                    <li style="margin-bottom:15px;">
                        📞 <b>Real-time Support:</b> Ask questions freely and get actionable guidance for better crop yield.
                    </li>
                    <li style="margin-bottom:15px;">
                        🤝 <b>Expert Collaboration:</b> Experienced agricultural experts can join the platform to assist farmers.
                    </li>
                </ul>

                <p style="margin-top:20px; background:#eaf6ea; padding:15px; border-left:5px solid #1a3d1a; border-radius:5px;">
                    By connecting farmers, experts, and Kisan Kendra staff, <b>AgriIntel Advisory System</b> modernizes agriculture while preserving the traditional support networks that farmers rely on.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- About Area End -->
