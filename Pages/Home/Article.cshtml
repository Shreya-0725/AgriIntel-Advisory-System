@page
@model AgriIntel_Advisory_System.Pages.Home.ArticleModel
@{
    Layout = "_Layout";
}

<style>

    /* ================= PAGE BANNER ================= */

    .page-banner-area {
        background-image: url('/assets/img/articleimage2.jpg');
        background-position: center;
        background-size: cover;
        padding: 100px 0;
        text-align: center;
        color: white;
    }

        .page-banner-area h2 {
            color: white !important;
            font-weight: 800;
        }

    /* Language Buttons */

    .language-switch button {
        margin: 5px;
        padding: 8px 15px;
        background: #28a745;
        border: none;
        color: white;
        border-radius: 5px;
        cursor: pointer;
    }

        .language-switch button:hover {
            background: #218838;
        }

    /* ================= ARTICLE CARDS ================= */

    .articles-container {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        margin-top: 40px;
        justify-content: center;
    }

    .article-card {
        width: 350px;
        border: 1px solid #ddd;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        background: #fff;
    }

        .article-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
        }

    .btn-read-more {
        display: inline-block;
        margin-top: 10px;
        padding: 6px 12px;
        background: #28a745;
        color: white;
        border-radius: 5px;
        text-decoration: none;
    }

        .btn-read-more:hover {
            background: #218838;
        }

    /* ================= PAGINATION ================= */

    .pagination-btn {
        padding: 6px 12px;
        margin: 4px;
        border: 1px solid #28a745;
        color: #28a745;
        text-decoration: none;
        border-radius: 5px;
    }

        .pagination-btn.active {
            background: #28a745;
            color: white;
        }

</style>

<!-- ===================================================== -->
<!-- ✅ PAGE BANNER -->
<!-- ===================================================== -->

<div class="page-banner-area">

    <h2>Latest Articles & Farming Tips</h2>

    <!-- Language Switch -->
    <div class="language-switch mt-3">
        <button onclick="switchLang('en')">English</button>
        <button onclick="switchLang('hi')">हिन्दी</button>
    </div>

</div>

<!-- ===================================================== -->
<!-- ✅ IF READ MORE CLICKED -->

@if (Model.SelectedArticle != null)
{
    <div class="container mt-5">

        <h2>@Model.SelectedArticle.TitleEnglish</h2>

        <img src="@Model.SelectedArticle.ImagePath"
             width="400"
             style="border-radius:10px;" />

        <p class="mt-3">
            @Model.SelectedArticle.DescriptionEnglish
        </p>

        <hr />

        <h2>@Model.SelectedArticle.TitleHindi</h2>

        <p>
            @Model.SelectedArticle.DescriptionHindi
        </p>

        <a asp-page="/Home/Article"
           class="btn btn-success">
            Back to Articles
        </a>

    </div>
}

<!-- ===================================================== -->
<!-- ✅ ARTICLE LIST + PAGINATION -->
<!-- ===================================================== -->
@if (Model.SelectedArticle == null)
{
    <div class="container articles-container">

        @foreach (var item in Model.Articles)
        {
            <div class="article-card">

                <img src="@item.ImagePath" />

                <h4 class="en">@item.TitleEnglish</h4>

                <p class="en">
                    @(item.DescriptionEnglish.Length > 120
                                ? item.DescriptionEnglish.Substring(0, 120) + "..."
                                : item.DescriptionEnglish)
                                                      </p>

                <h4 class="hi" style="display:none;">
                    @item.TitleHindi
                </h4>

                <p class="hi" style="display:none;">
                    @(item.DescriptionHindi.Length > 120
                                ? item.DescriptionHindi.Substring(0, 120) + "..."
                                : item.DescriptionHindi)
        </p>

                <a asp-page="/Home/Article"
                   asp-route-id="@item.ArticleId"
                   class="btn-read-more">
                    Read More
                </a>

            </div>
        }

    </div>

    <!-- ================= PAGINATION ================= -->

    <div class="text-center mt-4">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-page="/Home/Article"
               asp-route-pageNumber="@i"
               class="pagination-btn @(Model.PageNumber == i ? "active" : "")">
                @i
            </a>
        }

    </div>
}

<!-- ===================================================== -->
<!-- ✅ LANGUAGE TOGGLE SCRIPT -->
<!-- ===================================================== -->

<script>
    function switchLang(lang) {
        document.querySelectorAll('.en')
            .forEach(el => el.style.display = (lang === 'en') ? 'block' : 'none');

        document.querySelectorAll('.hi')
            .forEach(el => el.style.display = (lang === 'hi') ? 'block' : 'none');
    }
</script>