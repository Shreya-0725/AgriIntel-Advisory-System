@page
@model AgriIntel_Advisory_System.Pages.Home.LoginModel
@{
    Layout = "_Layout";
}

<style>

    body {
        background: #aabbb3;
        background-image: url('/assets/img/loginpage.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .login-wrapper {
        padding: 40px 20px;
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    
    .login-box {
        max-width: 450px;
        margin: auto;
        background: #dce6e1;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .form-title {
        background: #0f3d2e;
        color: white;
        padding: 10px;
        font-weight: 700;
        border-radius: 8px;
        text-align: center;
        margin-bottom: 20px;
    }

</style>

<div class="login-wrapper">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["ErrorMessage"]
        </div>
    }



    <!-- ROLE SELECT -->
    <select class="form-control mb-4" id="roleSelect" onchange="showForm()">
        <option value="">-- Select Role --</option>
        <option value="farmer">Farmer</option>
        <option value="expert">Expert</option>
        <option value="staff">Staff</option>
        <option value="kendra">Kisan Kendra</option>
    </select>

    <!-- ================= LOGIN FORM ================= -->

    <div id="loginBox" style="display:none;">
        <div class="login-box">

            <div class="form-title" id="loginTitle"></div>

            <form method="post">

                <!-- Identifier (Mobile / Email / Owner Name) -->
                <input asp-for="Login.Identifier"
                       class="form-control mb-3"
                       placeholder="Enter Username / Email / Mobile" />

                <!-- Password -->
                <input asp-for="Login.Password"
                       type="password"
                       class="form-control mb-3"
                       placeholder="Password" />

                <!-- Hidden Role Field -->
                <input type="hidden" asp-for="SelectedRole" id="roleField" />

                <button class="btn btn-success w-100">
                    Login
                </button>

            </form>
        </div>
    </div>

</div>

<script>

    function showForm() {

        let role = document.getElementById("roleSelect").value;

        if (role === "") {
            document.getElementById("loginBox").style.display = "none";
            return;
        }

        // ✅ Show login form
        document.getElementById("loginBox").style.display = "block";
        document.getElementById("roleField").value = role;

        document.getElementById("loginTitle").innerText =
            role.charAt(0).toUpperCase() + role.slice(1) + " Login";

        // ✅ Hide ONLY the dropdown (NOT container, NOT layout)
        document.getElementById("roleSelect").style.display = "none";
    }

</script>